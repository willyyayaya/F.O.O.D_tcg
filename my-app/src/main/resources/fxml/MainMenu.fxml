<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.game.ui.MainMenuController"
            prefHeight="768.0" prefWidth="1024.0"
            styleClass="main-menu-background">
    
    <!-- 背景樣式將在CSS中定義 -->
    <stylesheets>
        <String fx:value="/styles/main.css" />
    </stylesheets>
    
    <!-- 頂部標題區域 -->
    <top>
        <VBox alignment="CENTER" spacing="20.0">
            <padding>
                <Insets top="50.0" />
            </padding>
            <Label text="F.O.O.D TCG" styleClass="game-logo-text">
                <font>
                    <Font name="System Bold" size="64.0"/>
                </font>
            </Label>
            <Label text="食物擬人對戰卡牌遊戲" styleClass="game-title">
                <font>
                    <Font name="System Bold" size="36.0"/>
                </font>
            </Label>
        </VBox>
    </top>
    
    <!-- 中間菜單選項 -->
    <center>
        <VBox fx:id="menuContainer" alignment="CENTER" spacing="30.0" styleClass="menu-container">
            <padding>
                <Insets top="50.0" />
            </padding>
            
            <Button fx:id="startGameButton" text="開始遊戲" styleClass="menu-button">
                <font>
                    <Font size="24.0" />
                </font>
                <prefWidth>250.0</prefWidth>
                <prefHeight>60.0</prefHeight>
            </Button>
            
            <Button fx:id="gameRulesButton" text="遊戲規則" styleClass="menu-button">
                <font>
                    <Font size="24.0" />
                </font>
                <prefWidth>250.0</prefWidth>
                <prefHeight>60.0</prefHeight>
            </Button>
            
            <Button fx:id="cardLibraryButton" text="卡牌圖鑑" styleClass="menu-button">
                <font>
                    <Font size="24.0" />
                </font>
                <prefWidth>250.0</prefWidth>
                <prefHeight>60.0</prefHeight>
            </Button>
            
            <Button fx:id="exitButton" text="退出遊戲" styleClass="menu-button">
                <font>
                    <Font size="24.0" />
                </font>
                <prefWidth>250.0</prefWidth>
                <prefHeight>60.0</prefHeight>
            </Button>
        </VBox>
    </center>
    
    <!-- 底部版本信息 -->
    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <padding>
                <Insets bottom="10.0" right="20.0" />
            </padding>
            <Label fx:id="versionLabel" text="版本 1.0.0" styleClass="version-label" />
        </HBox>
    </bottom>
    
</BorderPane> 